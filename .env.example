# Per-repository tokens used by the /api/bugs route (server-side only).
# These are NEVER sent to the browser — do not prefix them with VITE_.
#
# Each token must be allowed to create issues on its repo. Use either:
#   - a classic Personal Access Token with the "repo" scope, or
#   - a fine-grained token with "Issues: Read and write" on that repo.
#
# After setting these, restart the dev server.

# FoodimeRepo/foodime
FOODIME_TOKEN=
# soundmade-com/soundmade
SOUNDMADE_TOKEN=
# wewaive/wewaive
WEWAIVE_TOKEN=
# kiibee-app/kiibee
KIIBEE_TOKEN=
